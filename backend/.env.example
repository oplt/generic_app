APP_NAME=fullstack-app
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_FILE_PATH=logs/logs.txt
LOG_RETENTION_DAYS=1
LOG_FORMAT=text
SLOW_REQUEST_MS=1000
SLOW_JOB_MS=5000
SLOW_EXTERNAL_CALL_MS=3000
CORE_DOMAIN_SINGULAR=Project
CORE_DOMAIN_PLURAL=Projects
PLATFORM_DEFAULT_MODULE_PACK=full_platform

DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app_db
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
# Cache TTLs (seconds)
CACHE_EMBEDDING_TTL_SECONDS=600
CACHE_EMBEDDING_MAX_TEXT_CHARS=4000
CACHE_RETRIEVAL_TTL_SECONDS=180
CACHE_PLATFORM_TTL_SECONDS=300
CACHE_SETTINGS_TTL_SECONDS=60
CACHE_OBSERVABILITY_STATUS_TTL_SECONDS=30
CACHE_MEMORY_SEARCH_TTL_SECONDS=60
CACHE_QUERY_EMBEDDING_TTL_SECONDS=3600
CACHE_USER_PROFILE_TTL_SECONDS=90
CACHE_PROJECT_LIST_TTL_SECONDS=30
CACHE_CALENDAR_TTL_SECONDS=60
CACHE_USER_DIRECTORY_TTL_SECONDS=60
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Dev-only: run Celery tasks in-process (indexing uses background threads; email uses create_task).
# Set to false and run `make worker` (or equivalent) in production.
CELERY_TASK_ALWAYS_EAGER=true
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_EMAIL_QUEUE=email
CELERY_RESULT_EXPIRES_SECONDS=3600

JWT_SECRET=replace-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:5173
ADMIN_SIGNUP_INVITE_CODE=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
PUBLIC_RATE_LIMIT_REQUESTS=120
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_FAILURE_LIMIT=8
AUTH_FAILURE_WINDOW_SECONDS=900
HEALTH_READY_PUBLIC=false
HEALTH_VERSION_PUBLIC=false
REQUIRE_EMAIL_VERIFICATION=true

VERIFICATION_TOKEN_TTL=86400
PASSWORD_RESET_TOKEN_TTL=3600

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=false

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
OTLP_ENDPOINT=
OTLP_INSECURE=true
OTEL_SERVICE_NAME=fastapi-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
GRAFANA_PUBLIC_URL=http://localhost:3001
PROMETHEUS_PUBLIC_URL=http://localhost:9090
TEMPO_PUBLIC_URL=http://localhost:3200
GRAFANA_APP_OVERVIEW_DASHBOARD_PATH=/d/fastapi-overview/fastapi-overview
GRAFANA_API_DASHBOARD_PATH=/d/fastapi-overview/fastapi-overview
GRAFANA_FRONTEND_DASHBOARD_PATH=
GRAFANA_DATABASE_DASHBOARD_PATH=
GRAFANA_CACHE_DASHBOARD_PATH=
GRAFANA_WORKERS_DASHBOARD_PATH=
GRAFANA_SCHEDULED_TASKS_DASHBOARD_PATH=
GRAFANA_ERRORS_DASHBOARD_PATH=/d/fastapi-overview/fastapi-overview
GRAFANA_TEMPO_EXPLORE_PATH=/explore

STORAGE_BUCKET=app-assets
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=change-this-storage-access-key
STORAGE_SECRET_KEY=change-this-storage-secret-key
STORAGE_USE_SSL=false
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/app-assets
STORAGE_AUTO_CREATE_BUCKET=true
STORAGE_PUBLIC_READ=true
STORAGE_AVATAR_MAX_BYTES=5242880

# Mem0 agent memory (optional — chat degrades gracefully when unavailable)
MEM0_MODE=hosted
MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_BASE_URL=
MEMORY_ENABLED=true
MEMORY_WRITE_ENABLED=true
MEMORY_AUDIT_ENABLED=true
MEMORY_DEFAULT_LIMIT=10
MEMORY_MIN_CONFIDENCE=0.65
MEMORY_SESSION_TTL_DAYS=30

# RAG (LangChain-backed document retrieval)
RAG_ENABLED=true
RAG_VECTOR_BACKEND=pgvector
RAG_EMBEDDING_PROVIDER=
# Empty inherits AI_EMBEDDING_PROVIDER
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
RAG_MAX_CONTEXT_TOKENS=6000
RAG_ALLOWED_FILE_TYPES=pdf,txt,md,docx,csv
RAG_MAX_FILE_BYTES=10485760
RAG_ASK_PROMPT_TEMPLATE_KEY=rag-answer
