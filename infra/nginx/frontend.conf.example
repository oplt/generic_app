# Example nginx config for serving the Vite frontend build (`frontend/dist`).
#
# Hashed assets under /assets/ can be cached aggressively. index.html should stay fresh
# so deployments roll out without clients pinning an old bundle manifest.
#
# If nginx also proxies the API, keep platform metadata short-lived so feature flags
# and module packs refresh quickly (align with CACHE_PLATFORM_TTL_SECONDS, default 300s):
#
#   location /api/v1/platform/metadata {
#       proxy_pass http://backend:8000;
#       add_header Cache-Control "private, max-age=300";
#   }

server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    location / {
        add_header Cache-Control "no-cache";
        try_files $uri /index.html;
    }
}
